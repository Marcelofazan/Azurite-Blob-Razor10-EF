@model exemploBlobAzure.Models.Usuario

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Usuario</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="UsuarioID" />
            <div class="form-group">
                <label asp-for="UsuarioNome" class="control-label"></label>
                <input asp-for="UsuarioNome" class="form-control" />
                <span asp-validation-for="UsuarioNome" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="UsuarioImageUrl" class="control-label"></label>
                <input asp-for="UsuarioImageUrl" class="form-control" disabled />
                <span asp-validation-for="UsuarioImageUrl" class="text-danger"></span>
            </div>
            <div class="form-group">
                @if (!string.IsNullOrEmpty(Model.UsuarioImageUrl))
                {
                    <img id="imagePreview" src="@Model.UsuarioImageUrl" width="120" class="img-thumbnail" alt="Usuario Image" />
                }
                else
                {
                    <img id="imagePreview" src="" width="120" class="img-thumbnail d-none" alt="Usuario Image" />
                    <span id="noImageText" class="text-muted">No image</span>
                }
            </div>
            <div class="form-group mb-3">
                <label class="control-label">Upload Image</label>
                <input type="file" id="imageInput" name="imageFile" class="form-control" accept="image/*" />
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.getElementById('imageInput').addEventListener('change', function(event) {
            const file = event.target.files[0];
            const preview = document.getElementById('imagePreview');
            const noImageText = document.getElementById('noImageText');

            if (file) {
                const reader = new FileReader();

                reader.onload = function(e) {
                    // Atualiza o src da imagem com o arquivo local carregado
                    preview.src = e.target.result;
                    preview.classList.remove('d-none'); // Garante que a imagem apareça

                    if (noImageText) {
                        noImageText.classList.add('d-none'); // Esconde o texto "No image"
                    }
                };

                reader.readAsDataURL(file);
            }
        });
    </script>
}
